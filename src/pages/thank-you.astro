---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Thank you for contacting Cascade Concrete Co. We'll be in touch within 1 business day."
>
  <section class="py-32 px-4 text-center">
    <div class="max-w-lg mx-auto">
      <h1 class="text-white mb-4">We Got It.</h1>
      <p class="text-text-muted mb-8">
        Thanks for reaching out. Our team will follow up within 1 business day.
      </p>
      <a href="/" class="text-green hover:text-green-dark transition-colors font-semibold">
        ← Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
