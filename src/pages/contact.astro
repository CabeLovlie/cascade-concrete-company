---
import BaseLayout from '../layouts/BaseLayout.astro';
import EstimateForm from '../components/EstimateForm.astro';
import { Phone, MapPin, Clock } from '@lucide/astro';
---

<BaseLayout
  title="Contact & Free Estimate — Cascade Concrete Co."
  description="Request a free estimate from Cascade Concrete Co. in South King County, WA. Driveways, patios, foundations & excavation."
  mobileCta="inner"
>
  <section
    class="page-hero"
    style="background-image: linear-gradient(rgba(10,10,10,0.80), rgba(10,10,10,0.80)), url('/images/mac_stairs_complete_01.jpg');"
  >
    <div>
      <p class="eyebrow text-green">Get in Touch</p>
      <h1>Contact Cascade Concrete Co.</h1>
      <p>Free estimates. Honest pricing. Licensed, bonded, and insured.</p>
    </div>
  </section>

  <section class="bg-white py-20 md:py-24 px-6 md:px-16">
    <div class="section-container grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-16">
      <div>
        <h2 class="font-display text-[clamp(28px,3.5vw,42px)] tracking-[0.02em] text-text mb-4">Let's Talk About Your Project</h2>
        <p class="text-[15px] text-text-mid leading-[1.7] mb-8">
          Call or fill out the form and we'll follow up within 1 business day.
        </p>

        <ul class="space-y-5">
          <li class="flex items-center gap-3">
            <Phone size={20} class="text-green flex-shrink-0" />
            <a href="tel:+12535550182" class="font-mono text-lg text-text hover:text-green transition-colors">(253) 555-0182</a>
          </li>
          <li class="flex items-center gap-3">
            <MapPin size={20} class="text-green flex-shrink-0" />
            <span class="text-[15px] text-text-mid">South King County, WA</span>
          </li>
          <li class="flex items-center gap-3">
            <Clock size={20} class="text-green flex-shrink-0" />
            <span class="text-[15px] text-text-mid">Mon–Sat: 7am–6pm</span>
          </li>
        </ul>

        <p class="text-sm text-[#666666] leading-relaxed mt-5">
          Serving Auburn, Kent, Federal Way, Renton, Covington, Maple Valley, Burien, Tukwila, SeaTac, and surrounding South King County.
        </p>
      </div>

      <div>
        <EstimateForm variant="light" />
      </div>
    </div>
  </section>

  <section style="width: 100%; margin-top: 0;">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d43147.96!2d-122.2320508!3d47.3073398!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x54905e5ed2f2b42f%3A0x99d17c2fe60d7b1c!2sAuburn%2C%20WA!5e0!3m2!1sen!2sus!4v1"
      width="100%"
      height="420"
      style="border: 0; display: block;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Cascade Concrete Co. Service Area — South King County, WA"
    ></iframe>
  </section>
</BaseLayout>
