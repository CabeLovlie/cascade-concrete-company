---
import BaseLayout from '../layouts/BaseLayout.astro';
import BeforeAfterSection from '../components/BeforeAfterSection.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import CtaBand from '../components/CtaBand.astro';

const allGalleryItems = [
 { src: '/images/mac_brick_after01.webp', caption: 'Driveway Replacement · Seattle, WA' },
 { src: '/images/mac_dark-blue_after01.webp', caption: 'Residential Walkway' },
 { src: '/images/mac_dark-blue_after02.webp', caption: 'Covered Driveway' },
 { src: '/images/mac_walkway_01.jpg', caption: 'Commercial Sidewalk · South King County' },
 { src: '/images/mac_patio_complete_04.webp', caption: 'Covered Patio Slab' },
 { src: '/images/mac_driveway_complete_02.webp', caption: 'Full Driveway and Walkway Replacement' },
 { src: '/images/mac_working_04.jpg', caption: 'Shop Slab Prep - South King County' },
 { src: '/images/mac_slab_complete_01.jpg', caption: 'Shop Slab · South King County' },
  { src: '/images/mac_stairs_complete_01.jpg', caption: 'Entry Steps · South King County, WA' },
 { src: '/images/mac_foundation_complete01.jpg', caption: 'Foundation Slab · South King County' },
 { src: '/images/mac_working_05.jpg', caption: 'Driveway Pour in Progress' },
 { src: '/images/mac_stairs_complete_02.jpg', caption: 'Recessed Concrete Stairs' },
];
---

<BaseLayout
 title="Our Work — Cascade Concrete Co."
 description="Before-and-after project photos from Cascade Concrete Co. — driveways, retaining walls, patios, and slabs across South King County."
 ogImage="/images/cascade_open_graph_preview.png"
 mobileCta="inner"
>
 <section
 class="page-hero"
 style="background-image: linear-gradient(rgba(10,10,10,0.78), rgba(10,10,10,0.78)), url('/images/mac_working_07.webp');"
 >
 <div>
 <p class="eyebrow text-green">Project Gallery</p>
 <h1>Our Work</h1>
      <p>Real jobs, real results. Every project completed by the Cascade Concrete team.</p>
 </div>
 </section>

 <BeforeAfterSection
 layout="work"
 extraPairs={[
 {
 before: '/images/mac_white-house_driveway_before01.jpg',
 after: '/images/mac_white-house_driveway_after01.jpg',
 caption: 'Driveway Replacement — White House, Seattle, WA',
 },
 ]}
 />

 <GalleryGrid
 eyebrow="All Project Photos"
 title="Concrete & Site Work Projects"
 subtitle="Every photo from recent residential and commercial projects across Auburn and South King County."
 items={allGalleryItems}
 showViewAll={false}
 />

 <CtaBand />
</BaseLayout>
