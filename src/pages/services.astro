---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const services = [
 {
 eyebrow: 'Driveways · Patios · Walkways',
 title: 'Residential Concrete',
 body: 'Flatwork is where most residential concrete projects start. Cascade Concrete Co. handles the full job — demo of the existing slab, excavation, base prep, forming, pour, and finishing. Broom finish standard, exposed aggregate available.',
 items: ['New driveway pours', 'Patio installation', 'Walkways & front entries', 'Exposed aggregate finish', 'Step replacement'],
 image: '/images/mac_driveway_complete_02.webp',
 bg: 'bg-white',
 id: 'residential',
 },
 {
 eyebrow: 'Foundations · Slabs · Pads',
 title: 'Structural Concrete',
 body: 'Shop pads, ADU foundations, garage floors, and barn slabs poured to spec. We handle rebar placement, form setting, and finishing in-house — no subcontractors.',
 items: ['Shop & garage slabs', 'ADU foundations', 'Barn & RV pads', 'Reinforced footings', 'Garage floor replacements'],
 image: '/images/mac_foundation_complete01.jpg',
 bg: 'bg-surface',
 id: 'structural',
 },
 {
 eyebrow: 'Demo · Grading · Excavation',
 title: 'Site Prep & Excavation',
 body: 'We bring our own equipment to every job. Demo, grading, and excavation handled with a clear schedule and consistent communication from start to finish.',
 items: ['Concrete demolition & removal', 'Site grading & leveling', 'Excavation', 'Trench work', 'Base prep & compaction'],
 image: '/images/mac_working_06.jpg',
 bg: 'bg-white',
 id: 'site-prep',
 },
 {
 eyebrow: 'Structural Walls',
 title: 'Retaining Walls',
 body: 'South King County properties deal with real grade changes. Cascade Concrete Co. builds structural concrete retaining walls designed for the load and soil conditions at your specific site.',
 items: ['Residential retaining walls', 'Tiered wall systems', 'Combination driveway & wall projects', 'Drainage consideration', 'High-grade finishing'],
 image: '/images/mac_retaining_wall.webp',
 bg: 'bg-surface',
 id: 'retaining-walls',
 },
 {
 eyebrow: 'Steps · Entries · Landings',
 title: 'Steps & Stairs',
 body: 'Entry steps, basement entries, and outdoor landings poured clean and level. We form and finish steps to match the existing architecture and site grade.',
 items: ['Front entry steps', 'Basement entry steps', 'Garage entry landings', 'Step replacement & repair'],
 image: '/images/mac_stairs_complete_01.jpg',
 bg: 'bg-white',
 },
 {
 eyebrow: 'Commercial & Municipal',
 title: 'Commercial Work',
 body: 'Sidewalks, commercial flatwork, and site concrete serving homeowners, property owners, and small commercial projects across South King County.',
 items: ['Commercial sidewalks', 'Parking lot flatwork', 'ADA ramp installation', 'Site prep for commercial builds'],
 image: '/images/mac_walkway_01.jpg',
 bg: 'bg-surface',
 },
];
---

<BaseLayout
 title="Concrete Services — Cascade Concrete Co."
  description="Residential concrete, foundations, retaining walls & excavation in South King County, WA. Built to licensed & insured standards."
 mobileCta="inner"
>
 <section
 class="page-hero"
 style="background-image: linear-gradient(rgba(10,10,10,0.78), rgba(10,10,10,0.78)), url('/images/mac_working_04.jpg');"
 >
 <div>
 <p class="eyebrow text-green">Services</p>
 <h1>Concrete &amp; Site Work Services</h1>
 <p>Built to licensed & insured standards. Serving Auburn and South King County.</p>
 </div>
 </section>

 {services.map((service, i) => (
 <section id={service.id} class={`${service.bg} py-20 px-6 md:px-16`}>
 <div class="section-container grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
 {i % 2 === 0 ? (
 <>
 <img src={service.image} alt={service.title} class="w-full h-[360px] object-cover rounded-sm" loading="lazy" />
 <div>
 <p class="eyebrow">{service.eyebrow}</p>
 <h2 class="font-display text-[clamp(28px,3.5vw,42px)] tracking-[0.02em] text-text mt-2 mb-4">{service.title}</h2>
 <p class="text-[15px] text-text-mid leading-[1.7] mb-5">{service.body}</p>
 <ul class="space-y-2 mb-6">
 {service.items.map((item) => (
 <li class="text-sm text-text-mid"><span class="text-green mr-2">—</span>{item}</li>
 ))}
 </ul>
 <a href="/contact" class="text-[13px] font-semibold text-green hover:text-green-dark transition-colors">Request an Estimate →</a>
 </div>
 </>
 ) : (
 <>
 <div class="md:order-1">
 <p class="eyebrow">{service.eyebrow}</p>
 <h2 class="font-display text-[clamp(28px,3.5vw,42px)] tracking-[0.02em] text-text mt-2 mb-4">{service.title}</h2>
 <p class="text-[15px] text-text-mid leading-[1.7] mb-5">{service.body}</p>
 <ul class="space-y-2 mb-6">
 {service.items.map((item) => (
 <li class="text-sm text-text-mid"><span class="text-green mr-2">—</span>{item}</li>
 ))}
 </ul>
 <a href="/contact" class="text-[13px] font-semibold text-green hover:text-green-dark transition-colors">Request an Estimate →</a>
 </div>
 <img src={service.image} alt={service.title} class="w-full h-[360px] object-cover rounded-sm md:order-2" loading="lazy" />
 </>
 )}
 </div>
 </section>
 ))}

 <CtaBand />
</BaseLayout>
