---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  mobileCta?: 'home' | 'inner' | false;
}

const { title, description, ogImage = '/images/cascade_open_graph_preview.png', mobileCta = false } = Astro.props;
const siteUrl = 'https://cascade-concrete-company.netlify.app';
const ogImageUrl = `${siteUrl}${ogImage}`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cascade Concrete Co." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/png" href="/images/cascade_open_graph_preview.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="be52a051-a37e-4c5b-a824-4dde4ad5edf7"></script>
  </head>
  <body>
    <Nav />
    {mobileCta && <StickyMobileCTA mode={mobileCta} />}
    <main class:list={[{ 'main--inner-mobile-cta': mobileCta === 'inner' }]}>
      <slot />
    </main>
    <Footer />
    <Lightbox />
  </body>
</html>
