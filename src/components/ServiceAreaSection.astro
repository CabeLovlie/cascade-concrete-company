---
const cities = [
 'Auburn',
 'Kent',
 'Federal Way',
 'Renton',
 'Covington',
 'Maple Valley',
 'Burien',
 'Tukwila',
 'SeaTac',
 'Seattle',
 'Tacoma',
 'South King County',
];
---

<section id="service-area" class="bg-surface py-20 px-6 md:px-16">
 <div class="section-container">
 <div class="section-header">
 <p class="eyebrow">Service Area</p>
 <h2>Serving Auburn &amp; South King County</h2>
 <p>Licensed, bonded, and insured concrete contractor serving homeowners, property owners, and small commercial projects throughout South King County.</p>
 </div>

 <div class="flex flex-wrap gap-2.5 mt-7">
 {cities.map((city) => (
 <span class="bg-white border border-border-mid text-[13px] font-medium text-text-mid px-4 py-1.5 rounded-sm">{city}</span>
 ))}
 </div>
 </div>
</section>
