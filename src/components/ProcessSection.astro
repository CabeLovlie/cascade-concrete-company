---
const steps = [
 {
 number: '01',
 title: 'Project Consultation',
 body: "Tell us about your project. We'll ask the right questions to understand scope, site conditions, and timeline.",
 },
 {
 number: '02',
 title: 'Site Visit & Estimate',
 body: 'We come to you, review the site, and provide a clear itemized estimate. No hidden charges, no pressure.',
 },
 {
 number: '03',
 title: 'Demo, Prep & Forms',
 body: 'Demolition, excavation, grading, and forming handled with clear scheduling and consistent communication from start to finish.',
 },
 {
 number: '04',
 title: 'Pour, Finish & Cleanup',
 body: 'The pour goes in on schedule. We finish the surface, protect the concrete, and leave the site clean.',
 },
];
---

<section class="bg-white py-20 md:py-24 px-6 md:px-16">
 <div class="section-container">
 <div class="section-header">
 <p class="eyebrow">How It Works</p>
 <h2>Our Concrete Process</h2>
 <p>A straightforward process from first contact to finished pour — no surprises, no subcontractors.</p>
 </div>

 <div class="max-w-[1000px] mx-auto flex flex-col md:flex-row">
 {steps.map((step, i) => (
 <>
 {i > 0 && (
 <div class="hidden md:block w-px h-20 bg-border self-center flex-shrink-0" aria-hidden="true"></div>
 )}
 <div class="flex-1 flex flex-col gap-3 md:pr-8 py-6 md:py-0">
 <span class="font-display text-[56px] leading-none text-border">{step.number}</span>
 <div class="w-8 h-0.5 bg-green"></div>
 <h3 class="font-display text-[19px] tracking-[0.04em] text-text">{step.title}</h3>
 <p class="text-[13px] text-[#666666] leading-[1.65]">{step.body}</p>
 </div>
 </>
 ))}
 </div>
 </div>
</section>
