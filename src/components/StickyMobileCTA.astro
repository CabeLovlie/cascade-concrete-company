---
interface Props {
 mode?: 'home' | 'inner';
}

const { mode = 'home' } = Astro.props;
const isInner = mode === 'inner';
---

<div
 id="sticky-mobile-cta"
 class:list={[{ visible: isInner, 'sticky-mobile-cta--inner': isInner }]}
 data-cta-mode={mode}
>
 <a href="/contact" class="sticky-mobile-cta-primary">Free Estimate</a>
 <a href="tel:+12535550182" class="sticky-mobile-cta-secondary">Call (253) 555-0182</a>
</div>

<style is:global>
 #sticky-mobile-cta {
 display: none;
 position: fixed;
 top: 56px;
 left: 0;
 right: 0;
 z-index: 45;
 background: #1a2035;
 padding: 10px 16px;
 gap: 10px;
 opacity: 0;
 transform: translateY(-100%);
 transition: opacity 0.3s ease, transform 0.3s ease;
 box-shadow: 0 2px 16px rgba(0, 0, 0, 0.2);
 pointer-events: none;
 }

 @media (max-width: 768px) {
 #sticky-mobile-cta {
 display: flex;
 }

 main.main--inner-mobile-cta {
 padding-top: 54px;
 }
 }

 #sticky-mobile-cta.visible {
 opacity: 1;
 transform: translateY(0);
 pointer-events: auto;
 }

 #sticky-mobile-cta.sticky-mobile-cta--inner {
 opacity: 1;
 transform: translateY(0);
 pointer-events: auto;
 transition: none;
 }

 #sticky-mobile-cta a {
 flex: 1;
 font-family: 'Inter', sans-serif;
 font-size: 12px;
 font-weight: 700;
 letter-spacing: 0.06em;
 text-transform: uppercase;
 padding: 12px 10px;
 border-radius: 2px;
 text-decoration: none;
 text-align: center;
 display: block;
 }

 #sticky-mobile-cta .sticky-mobile-cta-primary {
 background: #2db832;
 color: #ffffff;
 }

 #sticky-mobile-cta .sticky-mobile-cta-secondary {
 background: transparent;
 color: #ffffff;
 border: 1px solid rgba(255, 255, 255, 0.3);
 }
</style>

<script is:inline>
 function initStickyMobileCTA() {
 const stickyCTA = document.getElementById('sticky-mobile-cta');
 if (!stickyCTA || stickyCTA.dataset.ctaMode === 'inner') return;

 const hero = document.querySelector('[data-hero]');
 if (!hero) return;

 const observer = new IntersectionObserver(
 ([entry]) => {
 stickyCTA.classList.toggle('visible', !entry.isIntersecting);
 },
 { threshold: 0, rootMargin: '0px 0px -1px 0px' }
 );
 observer.observe(hero);
 }

 if (document.readyState === 'loading') {
 document.addEventListener('DOMContentLoaded', initStickyMobileCTA);
 } else {
 initStickyMobileCTA();
 }
</script>
