---
import { Menu, X } from '@lucide/astro';
---

<header class="sticky top-0 z-50 bg-white border-b-2 border-[#2db832]">
  <div class="flex items-center justify-between h-14 md:h-[68px] px-6 max-w-[1400px] mx-auto">
    <a href="/" class="flex items-center gap-2 no-underline flex-shrink-0">
      <!-- C mark badge -->
      <div class="flex items-center justify-center rounded-[5px] flex-shrink-0"
           style="width:30px;height:30px;background:#2c5f2e;">
        <svg width="20" height="20" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19.5 9.5C18 7.6 16 6.3 13.8 6.3C9.6 6.3 6.2 9.8 6.2 14C6.2 18.2 9.6 21.7 13.8 21.7C16 21.7 18 20.4 19.5 18.5"
                stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
      </div>
      <!-- Wordmark -->
      <div class="flex flex-col leading-none">
        <span class="font-extrabold uppercase tracking-wide text-[13px] text-gray-900">Cascade Concrete</span>
        <span class="font-normal uppercase tracking-widest text-[9px] text-gray-400 mt-[2px]">Co. &nbsp;·&nbsp; Auburn, WA</span>
      </div>
    </a>

    <nav class="hidden md:flex flex-1 justify-center gap-8">
      <a href="/services" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green transition-colors">Services</a>
      <a href="/work" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green transition-colors">Our Work</a>
      <a href="/reviews" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green transition-colors">Reviews</a>
      <a href="/contact" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green transition-colors">Contact</a>
    </nav>

    <div class="flex items-center gap-4 flex-shrink-0">
      <a href="tel:+12535550182" class="hidden md:block font-mono text-[13px] text-text hover:text-green transition-colors">(253) 555-0182</a>
      <a href="/contact" class="nav-cta-btn bg-green text-white font-bold text-xs uppercase tracking-[0.08em] px-4 py-2 rounded-sm hover:bg-green-dark transition-colors">Free Estimate</a>
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1 text-text-mid"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <Menu id="menu-icon" size={24} />
        <X id="close-icon" size={24} class="hidden" />
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-border bg-white">
    <div class="flex flex-col px-6 py-4 gap-4">
      <a href="/services" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green">Services</a>
      <a href="/work" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green">Our Work</a>
      <a href="/reviews" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green">Reviews</a>
      <a href="/contact" class="text-[13px] font-semibold uppercase tracking-[0.06em] text-text-mid hover:text-green">Contact</a>
      <a href="tel:+12535550182" class="font-mono text-[13px] text-text">(253) 555-0182</a>
    </div>
  </nav>
</header>

<style>
  @media (max-width: 768px) {
    .nav-cta-btn {
      display: none;
    }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    menuIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
