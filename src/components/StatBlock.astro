<section style="background:#0d1117; padding:80px 24px;">
  <div class="stat-block-container">
    <div class="stat-item">
      <span style="font-family:'Bebas Neue',sans-serif; font-size:clamp(56px,8vw,88px); line-height:1; color:#f0f0f0; letter-spacing:0.02em;">10+</span>
      <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.14em; color:#8a9ab0;">Years in Business</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span style="font-family:'Bebas Neue',sans-serif; font-size:clamp(56px,8vw,88px); line-height:1; color:#2db832; letter-spacing:0.02em;">Hundreds of</span>
      <span style="font-family:'Inter',sans-serif; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.14em; color:#8a9ab0;">Projects Completed</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat-item">
      <span style="font-family:'Bebas Neue',sans-serif; font-size:clamp(40px,6vw,72px); line-height:1; color:#f0f0f0; letter-spacing:0.02em;">Fully Insured</span>
    </div>
  </div>
</section>

<style>
  .stat-block-container {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex-wrap: nowrap;
    max-width: 760px;
    margin: 0 auto;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 0 40px;
  }

  .stat-divider {
    width: 1px;
    height: 56px;
    background: #2a3545;
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 640px) {
    .stat-block-container {
      flex-direction: column;
      gap: 40px;
    }

    .stat-divider {
      display: none;
    }
  }
</style>
