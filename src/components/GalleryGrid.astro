---
interface GalleryItem {
 src: string;
 caption: string;
}

interface Props {
 title?: string;
 subtitle?: string;
 eyebrow?: string;
 items?: GalleryItem[];
 showViewAll?: boolean;
}

const defaultItems: GalleryItem[] = [
 { src: '/images/mac_brick_after01.webp', caption: 'Driveway Replacement · Seattle, WA' },
 { src: '/images/mac_dark-blue_after02.webp', caption: 'Covered Driveway Slab' },
 { src: '/images/mac_walkway_01.jpg', caption: 'Residential Sidewalk · South King County' },
 { src: '/images/mac_patio_complete_04.webp', caption: 'Covered Patio Slab' },
 { src: '/images/mac_driveway_complete_02.webp', caption: 'Full Driveway & Walkway Replacement' },
 { src: '/images/mac_working_04.jpg', caption: 'Shop Slab Prep · South King County' },
 { src: '/images/mac_slab_complete_01.jpg', caption: 'Shop Slab · South King County' },
  { src: '/images/mac_stairs_complete_01.jpg', caption: 'Entry Steps · South King County, WA' },
];

const {
 title = 'Concrete & Site Work Projects',
 subtitle = 'A sample of recent residential projects across Auburn and South King County.',
 eyebrow = 'Recent Work',
 items = defaultItems,
 showViewAll = true,
} = Astro.props;
---

<section class="bg-surface">
 <div class="section-container px-6 md:px-16 pt-20 md:pt-24 pb-8">
 <div class="section-header">
 <p class="eyebrow">{eyebrow}</p>
 <h2>{title}</h2>
 <p>{subtitle}</p>
 </div>
 </div>

 <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-0">
 {items.map((item) => (
 <div
 class="gallery-item relative overflow-hidden aspect-[4/3]"
 data-lightbox="true"
 data-src={item.src}
 data-caption={item.caption}
 style="cursor: pointer;"
 >
 <img
 src={item.src}
 alt={item.caption}
 class="w-full h-full object-cover transition-transform duration-400 ease-in-out"
 loading="lazy"
 />
 <div class="gallery-caption absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/72 to-transparent px-3.5 pt-6 pb-3 text-xs font-semibold text-white uppercase tracking-[0.05em] opacity-0 transition-opacity duration-300">
 {item.caption}
 </div>
 </div>
 ))}
 </div>

 {showViewAll && (
 <div class="text-center py-10">
 <a href="/work" class="text-[13px] font-semibold text-green hover:text-green-dark transition-colors">
 View All Project Photos →
 </a>
 </div>
 )}
</section>
