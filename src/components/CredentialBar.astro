---
import { Star, Shield, Calendar, MapPin } from '@lucide/astro';
---

<section id="credential-bar" style="background:#2db832; padding:10px 24px;">
  <div class="credential-bar-inner">
    <div style="display:flex; align-items:center; gap:7px;">
      <Star size={13} color="white" />
      <span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:white;">4.5-Star Google Rated</span>
    </div>
    <span class="credential-separator">|</span>
    <div style="display:flex; align-items:center; gap:7px;">
      <Shield size={13} color="white" />
      <span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:white;">Washington State Licensed</span>
    </div>
    <span class="credential-separator">|</span>
    <div style="display:flex; align-items:center; gap:7px;">
      <Calendar size={13} color="white" />
      <span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:white;">10+ Years Experience</span>
    </div>
    <span class="credential-separator">|</span>
    <div style="display:flex; align-items:center; gap:7px;">
      <MapPin size={13} color="white" />
      <span style="font-family:'Inter',sans-serif; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:white;">South King County, WA Based</span>
    </div>
  </div>
</section>

<style>
  .credential-bar-inner {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    gap: 0 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .credential-separator {
    color: rgba(255, 255, 255, 0.3);
    font-size: 10px;
    padding: 0 2px;
  }

  @media (max-width: 640px) {
    .credential-bar-inner {
      flex-wrap: wrap;
      gap: 8px 16px;
    }
  }
</style>
