---
import { ChevronDown } from '@lucide/astro';
---

<section
  class="bg-cover bg-center bg-no-repeat"
  style="min-height: 100vh; position: relative; display: flex; align-items: center; background-image: linear-gradient(to right, rgba(13,17,23,0.92) 0%, rgba(13,17,23,0.75) 50%, rgba(13,17,23,0.3) 100%), url('/images/mac_working_01.jpg');"
>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-16 py-24 w-full">
    <div class="max-w-[560px]">
      <p class="eyebrow eyebrow-line mb-6">SOUTH KING COUNTY, WA · LICENSED & INSURED</p>

      <h1 class="text-white mb-6">
        South King County's<br />
        <span class="text-green">Concrete</span> Crew.
      </h1>

      <p class="text-text-muted text-base mb-8 max-w-lg">
        Driveways, patios, retaining walls, foundations, and excavation — built right the first time.
        Serving Auburn and South King County for over 10 years.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/contact" class="btn-primary">GET A FREE ESTIMATE</a>
        <a href="/work" class="btn-secondary">See Our Work</a>
      </div>
    </div>
  </div>

  <!-- Seattle skyline watermark -->
  <div class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none overflow-hidden">
    <svg
      viewBox="0 0 1200 80"
      class="w-full h-full opacity-[0.05]"
      fill="white"
      preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
    >
      <rect x="0" y="50" width="1200" height="30" />
      <rect x="20" y="35" width="40" height="45" />
      <rect x="70" y="25" width="30" height="55" />
      <rect x="110" y="40" width="50" height="40" />
      <rect x="170" y="30" width="25" height="50" />
      <rect x="205" y="20" width="35" height="60" />
      <rect x="250" y="35" width="45" height="45" />
      <!-- Space Needle -->
      <polygon points="520,80 530,15 540,80" />
      <rect x="525" y="30" width="10" height="8" />
      <ellipse cx="530" cy="12" rx="18" ry="6" />
      <rect x="580" y="25" width="40" height="55" />
      <rect x="630" y="35" width="30" height="45" />
      <rect x="670" y="20" width="50" height="60" />
      <rect x="730" y="30" width="35" height="50" />
      <rect x="775" y="40" width="60" height="40" />
      <rect x="845" y="25" width="40" height="55" />
      <rect x="895" y="35" width="55" height="45" />
      <rect x="960" y="20" width="30" height="60" />
      <rect x="1000" y="30" width="45" height="50" />
      <rect x="1055" y="40" width="50" height="40" />
      <rect x="1115" y="25" width="40" height="55" />
    </svg>
  </div>

  <a
    href="#credential-bar"
    aria-label="Scroll down"
    style="position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%); opacity: 0.6; color: white; display: flex; align-items: center; justify-content: center; animation: bounce-y 1.8s ease-in-out infinite; z-index: 20;"
  >
    <ChevronDown size={28} color="white" />
  </a>
</section>

<style>
  @keyframes bounce-y {
    0%, 100% { transform: translateX(-50%) translateY(0px); }
    50%       { transform: translateX(-50%) translateY(10px); }
  }
</style>
