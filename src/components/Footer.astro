---
import FacebookIcon from './FacebookIcon.astro';
---

<footer class="bg-charcoal text-white">
  <div class="max-w-content mx-auto px-6 md:px-16 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <p class="mb-4">
          <span class="font-bold tracking-tight text-xl leading-none text-white">CASCADE CONCRETE <span class="font-normal">Co.</span></span>
        </p>
        <p class="text-[13px] text-white/45 leading-[1.65] mb-4">
          Portfolio concept for a concrete and excavation contractor serving Auburn and South King County. Driveways, foundations, retaining walls, slabs, demo, and site prep.
        </p>
        <p class="text-xs text-white/40">Licensed & Insured Standards</p>
      </div>

      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-[0.14em] text-white/35 mb-4">Services</h4>
        <ul class="space-y-2">
          <li><a href="/services" class="text-[13px] text-white/55 hover:text-white transition-colors">Residential Concrete</a></li>
          <li><a href="/services" class="text-[13px] text-white/55 hover:text-white transition-colors">Foundations &amp; Slabs</a></li>
          <li><a href="/services" class="text-[13px] text-white/55 hover:text-white transition-colors">Retaining Walls</a></li>
          <li><a href="/services" class="text-[13px] text-white/55 hover:text-white transition-colors">Excavation &amp; Demo</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-[0.14em] text-white/35 mb-4">Company</h4>
        <ul class="space-y-2">
          <li><a href="/work" class="text-[13px] text-white/55 hover:text-white transition-colors">Our Work</a></li>
          <li><a href="/reviews" class="text-[13px] text-white/55 hover:text-white transition-colors">Reviews</a></li>
          <li><a href="/#service-area" class="text-[13px] text-white/55 hover:text-white transition-colors">Service Area</a></li>
          <li><a href="/contact" class="text-[13px] text-white/55 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] font-bold uppercase tracking-[0.14em] text-white/35 mb-4">Contact</h4>
        <ul class="space-y-3">
          <li>
            <a href="tel:+12535550182" class="font-mono text-sm text-white hover:text-green transition-colors">(253) 555-0182</a>
          </li>
          <li>
            <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[13px] text-white/55 hover:text-white transition-colors" aria-label="Facebook">
              <FacebookIcon size={18} />
              Facebook
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[13px] text-white/55 hover:text-white transition-colors" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/[0.08] mt-12 pt-5 flex flex-col gap-3">
      <p class="text-xs text-gray-400 italic mt-2 text-center sm:text-left">
        Portfolio concept by Cabriel Lovlie Web Design. Cascade Concrete Co. is a fictional contractor brand
        created to showcase website design, layout, and conversion strategy. It does not represent an active business.
      </p>
      <div class="flex flex-col sm:flex-row justify-between gap-2 text-xs text-white/25">
        <span>&copy; {new Date().getFullYear()} Cascade Concrete Co.</span>
        <span>Licensed & Insured Standards</span>
      </div>
    </div>
  </div>
</footer>
